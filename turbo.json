{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "docs:api"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "docs:api": {
      "outputs": ["docs/api/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
